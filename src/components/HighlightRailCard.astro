---
import type { HighlightItem } from '../utils/content';
import { transformCloudinaryUrl } from '../utils/images';

interface Props {
  item: HighlightItem;
}

const { item } = Astro.props;
const image = item.image ? transformCloudinaryUrl(item.image, 1400) : undefined;
const formattedDate = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  year: 'numeric',
}).format(item.date);
---
<article class="w-[20rem] flex-none snap-start md:w-[25rem]">
  <a href={item.href} class="group block">
    {image ? (
      <div
        class="overflow-hidden rounded-[1.8rem] bg-stone-200"
        style={`aspect-ratio: ${item.aspectRatio};`}
      >
        <img
          src={image}
          alt={item.title}
          class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="flex min-h-[18rem] items-end rounded-[1.8rem] border border-black/10 bg-[rgba(255,255,255,0.45)] p-6">
        <p class="max-w-xs text-xl font-serif leading-tight text-neutral-900">{item.title}</p>
      </div>
    )}

    <div class="mt-4 space-y-2">
      <div class="flex items-center gap-3 text-[11px] uppercase tracking-[0.24em] text-neutral-500">
        <span>{item.kind === 'writing' ? 'Writing' : 'Travel'}</span>
        <span>{formattedDate}</span>
      </div>
      <h3 class="text-2xl font-serif leading-tight text-neutral-900 transition group-hover:opacity-75">
        {item.title}
      </h3>
      <p class="max-w-sm text-sm leading-6 text-neutral-600">{item.description}</p>
    </div>
  </a>
</article>
