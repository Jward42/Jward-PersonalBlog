<header class="sticky top-0 z-10 w-full border-b bg-white/80 backdrop-blur-md">
  <div class="mx-auto max-w-screen-xl px-4 py-4 flex items-center justify-between">
    <a href="/" class="font-bold text-xl tracking-tight">EH • Portfolio</a>
    
    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-8 text-sm font-medium">
      <a href="/blog" class="hover:text-blue-600 transition-colors">Blog</a>
      <a href="/photography" class="hover:text-blue-600 transition-colors">Photography</a>
      <a href="/about" class="hover:text-blue-600 transition-colors">About</a>
    </nav>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="md:hidden p-2 text-neutral-600 hover:text-neutral-900 focus:outline-none" aria-label="Toggle menu">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>

  <!-- Mobile Navigation Menu (Hidden by default) -->
  <div id="mobile-menu" class="hidden md:hidden border-t bg-white px-4 py-4 shadow-lg absolute w-full left-0">
    <nav class="flex flex-col gap-4 text-base font-medium">
      <a href="/blog" class="block py-2 hover:text-blue-600">Blog</a>
      <a href="/photography" class="block py-2 hover:text-blue-600">Photography</a>
      <a href="/about" class="block py-2 hover:text-blue-600">About</a>
    </nav>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>