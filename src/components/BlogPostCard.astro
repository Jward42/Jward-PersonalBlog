---
import type { CollectionEntry } from 'astro:content';
import Tag from './Tag.astro';
import { transformCloudinaryUrl } from '../utils/images';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const url = `/writing/${post.slug}`;
const imageUrl = post.data.heroImage ? transformCloudinaryUrl(post.data.heroImage, 800) : '';
const formattedDate = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
}).format(post.data.publishDate);
---
<article class="blog-post-card border-t border-black/10 pt-6" data-tags={post.data.tags.join(',')}>
  {post.data.heroImage && (
    <a href={url} class="group block overflow-hidden rounded-[1.35rem] bg-stone-200">
      <img
        src={imageUrl}
        alt={post.data.title}
        class="h-60 w-full object-cover transition duration-500 group-hover:scale-[1.03]"
        loading="lazy"
      />
    </a>
  )}

  <div class="mt-5 space-y-3">
    <p class="text-[11px] uppercase tracking-[0.24em] text-neutral-500">{formattedDate}</p>
    <a
      href={url}
      class="block text-2xl font-display leading-tight text-neutral-900 transition hover:opacity-75"
      transition:name={`blog-title-${post.slug}`}
    >
      {post.data.title}
    </a>
    <p class="max-w-xl text-sm leading-6 text-neutral-600">{post.data.description}</p>
    <div class="flex flex-wrap gap-2">
      {post.data.tags?.map((tag: string) => <Tag tag={tag} />)}
    </div>
  </div>
</article>
