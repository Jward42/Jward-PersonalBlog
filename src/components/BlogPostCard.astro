---
import type { CollectionEntry } from 'astro:content';
import Tag from './Tag.astro';
import { transformCloudinaryUrl } from '../utils/images';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const url = `/blog/${post.slug}`;

const imageUrl = post.data.heroImage ? transformCloudinaryUrl(post.data.heroImage, 800) : '';
---
<article class="blog-post-card rounded-2xl border p-5 hover:shadow-sm transition" data-tags={post.data.tags.join(',')}>
{post.data.heroImage && (
<a href={url} class="block mb-4">
<img
src={imageUrl}
alt={post.data.title}
class="w-full h-48 object-cover rounded-xl"
loading="lazy"
/>
</a>
)}
<a href={url} class="text-lg font-semibold hover:underline" transition:name={`blog-title-${post.slug}`}>{post.data.title}</a>
<p class="mt-2 text-sm text-neutral-600">{post.data.description}</p>
<div class="mt-3 flex flex-wrap gap-2">
{post.data.tags?.map((t: string) => <Tag tag={t} />)}
</div>
</article>