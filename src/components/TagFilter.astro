---
import { getCollection } from 'astro:content';
import TagPill from './TagPill.astro';
import { isVisibleContent } from '../utils/content';

const { type } = Astro.props as { type: 'blog' | 'photography' };
const entries = await getCollection(type, ({ data }) => isVisibleContent(data));
const allTags = [...new Set(entries.flatMap((entry) => entry.data.tags ?? []))].sort();
---

<div class="flex flex-wrap">
  {allTags.map(tag => <TagPill tag={tag} />)}
</div>
