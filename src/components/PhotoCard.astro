---
import type { CollectionEntry } from 'astro:content';
import { transformCloudinaryUrl } from '../utils/images';

interface Props {
  photo: CollectionEntry<'photography'>;
}

const { photo } = Astro.props;
const transformed = transformCloudinaryUrl(photo.data.imageUrl, 800);
---
<a href={`/photography/posts/${photo.slug}`} class="group relative block w-full overflow-hidden rounded-xl break-inside-avoid mb-4">
  <img 
    src={transformed} 
    alt={photo.data.title} 
    class="w-full h-auto transition-transform duration-500 group-hover:scale-105" 
    loading="lazy" 
  />
  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
  <div class="absolute bottom-0 left-0 p-4 translate-y-2 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
    <h2 class="text-white text-sm font-medium">
      {photo.data.title}
    </h2>
  </div>
</a>