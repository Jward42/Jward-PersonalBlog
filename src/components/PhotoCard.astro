---
import type { CollectionEntry } from 'astro:content';
import { transformCloudinaryUrl } from '../utils/images';

interface Props {
  photo: CollectionEntry<'photography'>;
}

const { photo } = Astro.props;
const transformed = transformCloudinaryUrl(photo.data.posterImage ?? photo.data.imageUrl, 1200);
---
<article class="travel-card break-inside-avoid mb-8" data-tags={photo.data.tags.join(',')}>
  <a href={`/travel/${photo.slug}`} class="group block">
    <div
      class="overflow-hidden rounded-[1.6rem] bg-stone-200"
      style={`aspect-ratio: ${photo.data.aspectRatio};`}
    >
      <img
        src={transformed}
        alt={photo.data.alt ?? photo.data.title}
        class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
        loading="lazy"
      />
    </div>
    <div class="mt-4">
      <p class="text-[11px] uppercase tracking-[0.24em] text-neutral-500">
        {photo.data.location ?? 'Travel'}
      </p>
      <h2 class="mt-2 text-2xl font-display leading-tight text-neutral-900 transition group-hover:opacity-75">
        {photo.data.title}
      </h2>
      {photo.data.description && (
        <p class="mt-2 text-sm leading-6 text-neutral-600">{photo.data.description}</p>
      )}
    </div>
  </a>
</article>
