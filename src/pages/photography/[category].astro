---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotoCard from '../../components/PhotoCard.astro';

export async function getStaticPaths() {
  const photos = await getCollection('photography');
  const categories = [...new Set(photos.map((p) => p.data.category).filter(Boolean))];
  
  return categories.map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.props;
const photos = (await getCollection('photography')).filter(
  (p) => p.data.category === category
);

const title = `Travel: ${category}`;
---
<BaseLayout {title} description={`A filtered travel view for ${category}.`}>
  <a href="/travel" class="text-sm text-neutral-600 transition hover:text-neutral-900">&larr; Back to Travel</a>
  <h1 class="mt-4 text-3xl font-display text-neutral-900">{title}</h1>
  
  <div class="mt-8 columns-1 md:columns-2 lg:columns-3 gap-4 space-y-4">
    {photos.map((p) => (
      <PhotoCard photo={p} />
    ))}
  </div>
</BaseLayout>
