---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { transformCloudinaryUrl } from '../../utils/images';

const categories = await getCollection('photoCategories');
---
<BaseLayout title="Photography Categories" description="A collection of photography by category.">
  <h1 class="text-2xl font-bold">Photography</h1>
  <p class="mt-2 text-neutral-600">Browse photography by category.</p>
  
  <div class="mt-8 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
    {categories.map(cat => (
      <a href={`/photography/${cat.data.name}`} class="group relative block w-full overflow-hidden rounded-lg aspect-[4/3]">
        <img 
          src={transformCloudinaryUrl(cat.data.coverImage, 800)} 
          alt={`Cover for ${cat.data.name}`}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy" 
        />
        <div class="absolute inset-0 bg-black/40"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <h2 class="text-white text-3xl font-bold" style="text-shadow: 1px 1px 3px rgba(0,0,0,0.7);">
            {cat.data.name}
          </h2>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
