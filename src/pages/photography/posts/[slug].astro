---
import { getCollection, type CollectionEntry } from 'astro:content';
import TravelEntryPage from '../../../components/TravelEntryPage.astro';
import { isVisibleContent } from '../../../utils/content';

export async function getStaticPaths() {
  const photos = await getCollection('photography', ({ data }) => isVisibleContent(data));
  return photos.map((photo) => ({
    params: { slug: photo.slug },
    props: { photo },
  }));
}

interface Props {
  photo: CollectionEntry<'photography'>;
}

const { photo } = Astro.props;
---
<TravelEntryPage photo={photo} />
