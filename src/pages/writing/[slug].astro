---
import type { CollectionEntry } from 'astro:content';
import WritingEntryPage from '../../components/WritingEntryPage.astro';
import { getWritingEntries } from '../../utils/content';

export async function getStaticPaths() {
  const posts = await getWritingEntries();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
---
<WritingEntryPage post={post} />
