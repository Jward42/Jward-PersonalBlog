---
import BaseLayout from '../layouts/BaseLayout.astro';
import HighlightRailCard from '../components/HighlightRailCard.astro';
import { getEntry } from 'astro:content';
import { getHomepageHighlights, getTravelEntries, getWritingEntries } from '../utils/content';
import { transformCloudinaryUrl } from '../utils/images';

const homepage = await getEntry('homepage', 'hero');
const [highlights, writingEntries, travelEntries] = await Promise.all([
  getHomepageHighlights(6),
  getWritingEntries(),
  getTravelEntries(),
]);

const latestWriting = writingEntries.slice(0, 3);
const latestTravel = travelEntries.slice(0, 3);
const heroImage = transformCloudinaryUrl(homepage.data.heroImage, 1800);
---
<BaseLayout title="Edward Han" description="A personal atlas of writing, travel, and visual notes.">
  <section class="grid gap-8 border-b border-black/10 pb-12 pt-6 lg:min-h-[38rem] lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
    <div class="order-2 lg:order-1">
      <p class="text-[11px] uppercase tracking-[0.34em] text-neutral-500">Jward Atlas</p>
      <h1 class="mt-5 max-w-3xl text-4xl font-display leading-tight text-neutral-900 md:text-6xl">
        {homepage.data.title}
      </h1>
      <p class="mt-6 max-w-xl text-sm leading-7 text-neutral-600 md:text-base">
        {homepage.data.description}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/writing" class="rounded-full border border-black/10 px-5 py-3 text-sm text-neutral-900 transition hover:bg-white/50">
          Enter Writing
        </a>
        <a href="/travel" class="rounded-full border border-black/10 px-5 py-3 text-sm text-neutral-900 transition hover:bg-white/50">
          Enter Travel
        </a>
      </div>
    </div>

    <div class="order-1 overflow-hidden rounded-[2.25rem] bg-stone-200 lg:order-2">
      <img
        src={heroImage}
        alt={homepage.data.heroImageAlt}
        class="h-[24rem] w-full object-cover md:h-[32rem] lg:h-[40rem]"
      />
    </div>
  </section>

  <section class="mt-12">
    <div class="flex items-center justify-between gap-6">
      <div>
        <p class="text-[11px] uppercase tracking-[0.3em] text-neutral-500">Highlights</p>
        <h2 class="mt-3 text-3xl font-display text-neutral-900 md:text-4xl">A curated rail of essays and images.</h2>
      </div>
      <a href="/travel" class="hidden text-sm text-neutral-600 transition hover:text-neutral-900 md:block">See all travel notes</a>
    </div>

    <div class="horizontal-scroll mt-8 flex gap-6 overflow-x-auto pb-3">
      {highlights.map((item) => <HighlightRailCard item={item} />)}
    </div>
  </section>

  <section class="mt-16 grid gap-12 border-t border-black/10 pt-10 lg:grid-cols-2">
    <div>
      <div class="flex items-center justify-between">
        <div>
          <p class="text-[11px] uppercase tracking-[0.3em] text-neutral-500">Latest</p>
          <h2 class="mt-3 text-3xl font-display text-neutral-900">Writing</h2>
        </div>
        <a href="/writing" class="text-sm text-neutral-600 transition hover:text-neutral-900">All writing</a>
      </div>

      <div class="mt-8 space-y-8">
        {latestWriting.length > 0 ? (
          latestWriting.map((post) => (
            <article class="border-t border-black/10 pt-6">
              <p class="text-[11px] uppercase tracking-[0.24em] text-neutral-500">
                {new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(post.data.publishDate)}
              </p>
              <a href={`/writing/${post.slug}`} class="mt-3 block text-2xl font-display leading-tight text-neutral-900 transition hover:opacity-75">
                {post.data.title}
              </a>
              <p class="mt-3 max-w-xl text-sm leading-6 text-neutral-600">{post.data.description}</p>
            </article>
          ))
        ) : (
          <article class="rounded-[1.8rem] border border-black/10 bg-white/35 p-6">
            <p class="text-[11px] uppercase tracking-[0.24em] text-neutral-500">Writing Placeholder</p>
            <p class="mt-3 max-w-xl text-sm leading-7 text-neutral-600">
              No placeholder essays are being shown here. This section will populate automatically once real writing is published.
            </p>
          </article>
        )}
      </div>
    </div>

    <div>
      <div class="flex items-center justify-between">
        <div>
          <p class="text-[11px] uppercase tracking-[0.3em] text-neutral-500">Latest</p>
          <h2 class="mt-3 text-3xl font-display text-neutral-900">Travel</h2>
        </div>
        <a href="/travel" class="text-sm text-neutral-600 transition hover:text-neutral-900">All travel</a>
      </div>

      <div class="mt-8 space-y-8">
        {latestTravel.map((entry) => (
          <article class="grid gap-5 border-t border-black/10 pt-6 md:grid-cols-[0.9fr_1.1fr]">
            <a
              href={`/travel/${entry.slug}`}
              class="overflow-hidden rounded-[1.4rem] bg-stone-200"
              style={`aspect-ratio: ${entry.data.aspectRatio};`}
            >
              <img
                src={transformCloudinaryUrl(entry.data.posterImage ?? entry.data.imageUrl, 1000)}
                alt={entry.data.alt ?? entry.data.title}
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </a>
            <div class="self-end">
              <p class="text-[11px] uppercase tracking-[0.24em] text-neutral-500">
                {entry.data.location ?? 'Travel'}
              </p>
              <a href={`/travel/${entry.slug}`} class="mt-3 block text-2xl font-display leading-tight text-neutral-900 transition hover:opacity-75">
                {entry.data.title}
              </a>
              <p class="mt-3 text-sm leading-6 text-neutral-600">{entry.data.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
