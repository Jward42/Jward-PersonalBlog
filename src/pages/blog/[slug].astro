---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.isDraft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(post.data.publishDate);
---
<BaseLayout title={`${post.data.title} — Blog`} description={post.data.description}>
  <header class="text-center pt-12 pb-8">
    <h1 class="text-4xl md:text-5xl font-bold !font-sans" transition:name={`blog-title-${post.slug}`}>{post.data.title}</h1>
    <p class="mt-4 text-base text-neutral-500">{formattedDate}</p>
  </header>
  <article class="prose prose-lg max-w-3xl mx-auto">
    <Content />
  </article>
</BaseLayout>